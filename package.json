{
  "name": "family-chores-pwa-mvp",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0",
    "test": "vitest run",
    "test:watch": "vitest",
    "seed": "tsx scripts/seedFirestore.ts",
    "deploy": "npm run build && firebase deploy --only hosting",
    "deploy:all": "npm run build && firebase deploy",
    "deploy:pages": "GITHUB_PAGES=true npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "firebase": "^12.0.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.8.0",
    "vite": "^7.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.0",
    "vitest": "^3.0.0"
  }
}
